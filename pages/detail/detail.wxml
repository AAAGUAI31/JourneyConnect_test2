<!--pages/detail/detail.wxml-->
<scroll-view scroll-y class="container">
  <!-- 活动封面 -->
  <view class="cover-section">
    <image class="cover-image" src="{{activity.cover}}" mode="aspectFill" />
    <view class="status-badge">
      <t-tag size="small" theme="success">{{activity.status}}</t-tag>
    </view>
  </view>

  <!-- 活动基本信息 -->
  <view class="info-section">
    <view class="activity-title">{{activity.title}}</view>
    
    <view class="info-list">
      <view class="info-item">
        <text class="info-icon">📅</text>
        <text class="info-text">{{activity.dateRange}}</text>
      </view>
      <view class="info-item">
        <text class="info-icon">📍</text>
        <text class="info-text">{{activity.location}}</text>
      </view>
    </view>

    <!-- 旅行风格标签 -->
    <view class="tags-container">
      <t-tag wx:for="{{activity.tags}}" wx:key="*this" wx:for-item="tag" size="small" theme="primary">{{tag}}</t-tag>
    </view>

    <!-- 报名人数 -->
    <view class="members-section">
      <view class="members-info">
        <text class="members-label">已报名</text>
        <text class="members-count">{{activity.currentMembers}}</text>
        <text class="members-separator">/</text>
        <text class="members-max">{{activity.maxMembers}}</text>
        <text class="members-unit">人</text>
      </view>
      <view class="members-avatars" bindtap="onShowMembers">
        <t-avatar wx:for="{{activity.members}}" wx:key="id" wx:for-item="member" size="{{64}}" image="{{member.avatar}}" />
        <view class="more-members" wx:if="{{activity.members.length < activity.currentMembers}}">
          <text>+{{activity.currentMembers - activity.members.length}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 行程安排 -->
  <view class="schedule-section">
    <view class="section-title">行程安排</view>
    <view class="schedule-content-text">{{activity.description}}</view>
  </view>

  <!-- 发起人信息 -->
  <view class="creator-section">
    <view class="section-title">发起人</view>
    <view class="creator-card">
      <t-avatar size="{{120}}" image="{{activity.creator.avatar}}" />
      <view class="creator-info">
        <view class="creator-name-row">
          <text class="creator-name">{{activity.creator.name}}</text>
          <t-tag size="small" theme="default">发起人</t-tag>
        </view>
        <view class="creator-contact">
          <text class="contact-icon">👤</text>
          <text class="contact-text">微信号：{{activity.creator.wechat}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 报名人员列表 -->
  <view class="members-list-section">
    <view class="section-title">报名人员（{{activity.currentMembers}}人）</view>
    <view class="members-list">
      <view
        wx:for="{{activity.members}}"
        wx:key="id"
        wx:for-item="member"
        class="member-item"
        bindtap="onMemberTap"
        data-member="{{member}}"
      >
        <t-avatar size="{{96}}" image="{{member.avatar}}" />
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">{{member.name}}</text>
            <t-tag wx:if="{{member.isCreator}}" size="small" theme="success">发起人</t-tag>
          </view>
          <text class="member-hint">点击查看详情</text>
        </view>
        <text class="member-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-placeholder"></view>
  <view class="footer-bar">
    <t-button 
      wx:if="{{isRegistered && !isCreator}}" 
      theme="default" 
      size="large" 
      block 
      disabled
    >
      已报名
    </t-button>
    <t-button 
      wx:elif="{{activity.currentMembers >= activity.maxMembers && !isCreator}}" 
      theme="default" 
      size="large" 
      block 
      disabled
    >
      已满员
    </t-button>
    <t-button 
      wx:else
      theme="primary" 
      size="large" 
      bindtap="{{isCreator ? 'onEditActivity' : 'onRegister'}}" 
      block
    >
      {{isCreator ? '完善报名信息' : '立即报名'}}
    </t-button>
  </view>
</scroll-view>

<!-- 报名弹窗 -->
<t-popup visible="{{showRegisterDialog}}" placement="bottom">
  <view class="register-popup-container">
    <view class="register-popup-header">
      <text class="register-popup-title">报名信息</text>
      <view class="register-popup-close" bindtap="onRegisterCancel">
        <text>×</text>
      </view>
    </view>

    <scroll-view scroll-y class="register-popup-content">
      <view class="register-form">
        <view class="form-item">
          <view class="form-label">姓名/昵称 *</view>
          <t-input placeholder="请输入姓名或昵称" value="{{registerForm.name}}" bind:change="onFormChange" data-field="name" />
        </view>
        <view class="form-item">
          <view class="form-label">性别 *</view>
          <t-radio-group value="{{registerForm.gender}}" bind:change="onGenderChange">
            <t-radio value="male" label="男" />
            <t-radio value="female" label="女" />
          </t-radio-group>
        </view>
        <view class="form-item">
          <view class="form-label">年龄（可选）</view>
          <t-input type="digit" placeholder="请输入年龄" value="{{registerForm.age}}" bind:change="onFormChange" data-field="age" />
        </view>
        <view class="form-item">
          <view class="form-label">联系方式 *</view>
          <t-input placeholder="微信号或手机号" value="{{registerForm.contact}}" bind:change="onFormChange" data-field="contact" />
        </view>
        <view class="form-item">
          <view class="form-label">自我介绍（可选）</view>
          <t-textarea placeholder="简单介绍一下自己..." value="{{registerForm.intro}}" bind:change="onFormChange" data-field="intro" maxlength="200" />
        </view>
        <view class="form-item">
          <view class="form-label">备注（可选）</view>
          <t-textarea placeholder="有什么需要告知组织者的，请填写..." value="{{registerForm.remark}}" bind:change="onFormChange" data-field="remark" maxlength="200" />
        </view>
      </view>
    </scroll-view>

    <view class="register-popup-footer">
      <t-button theme="default" size="large" bindtap="onRegisterCancel" style="margin-right: 16rpx; flex: 1;">
        取消
      </t-button>
      <t-button theme="primary" size="large" bindtap="onRegisterConfirm" style="flex: 1;">
        确认报名
      </t-button>
    </view>
  </view>
</t-popup>

<!-- 成员详情弹窗 -->
<t-popup visible="{{showMemberDetail}}" placement="bottom" bind:visible-change="onMemberDetailClose">
  <view class="member-detail-container" wx:if="{{selectedMember}}">
    <view class="member-detail-header">
      <text class="member-detail-title">成员信息</text>
      <view class="member-detail-close" bindtap="onMemberDetailClose">
        <text>×</text>
      </view>
    </view>
    <view class="member-detail-body">
      <view class="member-detail-profile">
        <t-avatar size="{{128}}" image="{{selectedMember.avatar}}" />
        <view class="member-detail-name-row">
          <text class="member-detail-name">{{selectedMember.name}}</text>
          <t-tag wx:if="{{selectedMember.isCreator}}" size="small" theme="success">发起人</t-tag>
        </view>
      </view>
      <view class="detail-info-list">
        <view class="detail-info-item" wx:if="{{selectedMember.gender}}">
          <text class="detail-info-label">性别</text>
          <text class="detail-info-value">{{selectedMember.gender === 'male' ? '男' : '女'}}</text>
        </view>
        <view class="detail-info-item" wx:if="{{selectedMember.age}}">
          <text class="detail-info-label">年龄</text>
          <text class="detail-info-value">{{selectedMember.age}} 岁</text>
        </view>
        <view class="detail-info-item" wx:if="{{selectedMember.contact}}">
          <text class="detail-info-label">联系方式</text>
          <text class="detail-info-value">{{selectedMember.contact}}</text>
        </view>
        <view class="detail-info-item" wx:if="{{selectedMember.intro}}">
          <text class="detail-info-label">自我介绍</text>
          <text class="detail-info-value">{{selectedMember.intro}}</text>
        </view>
        <view class="detail-info-item" wx:if="{{selectedMember.remark}}">
          <text class="detail-info-label">备注</text>
          <text class="detail-info-value">{{selectedMember.remark}}</text>
        </view>
        <view class="detail-info-empty"
          wx:if="{{!selectedMember.gender && !selectedMember.age && !selectedMember.contact && !selectedMember.intro && !selectedMember.remark}}"
        >
          <text>暂无更多信息</text>
        </view>
      </view>
    </view>
  </view>
</t-popup>

<!-- 编辑活动弹窗 -->
<t-popup visible="{{showEditDialog}}" placement="bottom">
  <view class="edit-popup-container">
    <view class="edit-popup-header">
      <text class="edit-popup-title">编辑活动</text>
      <view class="edit-popup-close" bindtap="onEditCancel">
        <text>×</text>
      </view>
    </view>
    
    <scroll-view scroll-y class="edit-popup-content">
      <view class="edit-form">
        <!-- 活动标题 -->
        <view class="form-item">
          <view class="form-label">活动标题 *</view>
          <t-input placeholder="请输入活动标题" value="{{editForm.title}}" bind:change="onEditFieldChange" data-field="title" />
        </view>

        <!-- 活动时间 -->
        <view class="form-item">
          <view class="form-label">活动时间 *</view>
          <view class="date-row">
            <view class="date-item">
              <view class="date-label">开始日期</view>
              <picker mode="date" value="{{editForm.startDate}}" bindchange="onEditStartDateChange">
                <view class="picker-content">{{editForm.startDate || '选择开始日期'}}</view>
              </picker>
            </view>
            <view class="date-item">
              <view class="date-label">结束日期</view>
              <picker mode="date" value="{{editForm.endDate}}" bindchange="onEditEndDateChange">
                <view class="picker-content">{{editForm.endDate || '选择结束日期'}}</view>
              </picker>
            </view>
          </view>
        </view>

        <!-- 活动地点 -->
        <view class="form-item">
          <view class="form-label">活动地点 *</view>
          <view class="location-row">
            <t-input class="location-input" placeholder="请输入地点" value="{{editForm.location}}" bind:change="onEditFieldChange" data-field="location" />
            <button class="location-btn" bindtap="onEditLocationSelect">
              <text class="location-icon">📍</text>
            </button>
          </view>
        </view>

        <!-- 行程描述 -->
        <view class="form-item">
          <view class="form-label">行程描述 *</view>
          <t-textarea placeholder="请按天描述详细的行程安排..." value="{{editForm.description}}" bind:change="onEditFieldChange" data-field="description" maxlength="500" rows="6" />
        </view>

        <!-- 旅行风格 -->
        <view class="form-item">
          <view class="form-label">旅行风格 *</view>
          <view class="tags-container">
            <t-tag 
              wx:for="{{styleTags}}" 
              wx:key="*this" 
              wx:for-item="tag"
              size="medium"
              theme="{{tagSelected[tag] === true ? 'primary' : 'default'}}"
              bindtap="onEditTagSelect"
              data-tag="{{tag}}"
            >
              {{tag}}
            </t-tag>
          </view>
        </view>

        <!-- 人数上限 -->
        <view class="form-item">
          <view class="form-label">人数上限 *</view>
          <view class="stepper-container">
            <t-stepper 
              value="{{editForm.maxMembers}}" 
              min="2" 
              max="50" 
              bind:change="onEditMaxMembersChange"
            />
            <text class="stepper-unit">人</text>
          </view>
        </view>

        <!-- 联系方式 -->
        <view class="form-item">
          <view class="form-label">联系方式 *</view>
          <t-input placeholder="微信号或手机号" value="{{editForm.contact}}" bind:change="onEditFieldChange" data-field="contact" />
        </view>

        <!-- 活动封面 -->
        <view class="form-item">
          <view class="form-label">活动封面</view>
          <view class="cover-upload-container">
            <!-- 图片预览 -->
            <view wx:if="{{editForm.coverFiles.length > 0}}" class="cover-preview">
              <view wx:if="{{editForm.coverFiles[0].url}}" style="width: 100%; height: 100%;">
                <image class="cover-image" src="{{editForm.coverFiles[0].url}}" mode="aspectFill" />
              </view>
              <view wx:elif="{{editForm.coverFiles[0].path}}" style="width: 100%; height: 100%;">
                <image class="cover-image" src="{{editForm.coverFiles[0].path}}" mode="aspectFill" />
              </view>
              <view wx:elif="{{editForm.coverFiles[0].tempFilePath}}" style="width: 100%; height: 100%;">
                <image class="cover-image" src="{{editForm.coverFiles[0].tempFilePath}}" mode="aspectFill" />
              </view>
              <view wx:else style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #999;">
                <text>无法显示预览（路径缺失）</text>
              </view>
              <view class="cover-delete" bindtap="onEditCoverDelete">
                <text class="delete-icon">×</text>
              </view>
            </view>
            <!-- 上传按钮（加号） -->
            <t-upload
              class="cover-upload-btn"
              files="{{editForm.coverFiles}}"
              max="1"
              media-type="image"
              grid-config="{{gridConfig}}"
              bind:change="onEditCoverChange"
              bind:success="onEditUploadSuccess"
              bind:fail="onEditUploadFail"
              bind:progress="onEditUploadProgress"
            >
              <view slot="add-content" class="upload-add-btn" bindtap="onEditManualChooseImage">
                <text class="add-icon">+</text>
              </view>
            </t-upload>
          </view>
          <view class="upload-hint-text">建议尺寸 750x400，支持 JPG、PNG</view>
        </view>
      </view>
    </scroll-view>

    <!-- 底部按钮 -->
    <view class="edit-popup-footer">
      <t-button theme="danger" size="large" bindtap="onDeleteActivity" style="margin-right: 16rpx; flex: 1;">
        删除活动
      </t-button>
      <t-button theme="primary" size="large" bindtap="onEditConfirm" style="flex: 1;">
        保存修改
      </t-button>
    </view>
  </view>
</t-popup>

