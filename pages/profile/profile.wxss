/* pages/profile/profile.wxss */
.container {
  width: 100%;
  height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.user-header {
  background: linear-gradient(135deg, #0052D9 0%, #1E88E5 100%);
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 32rpx);
}

.user-info-card {
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-wechat,
.user-signature {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.edit-avatar-img {
  width: 120rpx;
  height: 120rpx;
}

.edit-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon {
  font-size: 32rpx;
}

.stats-card {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  margin-top: -24rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-divider {
  border-left: 1rpx solid #f0f0f0;
  border-right: 1rpx solid #f0f0f0;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
}

.tabs-container {
  background-color: #ffffff;
  margin-top: 16rpx;
}

.activities-list {
  padding: 32rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.activity-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.card-content {
  display: flex;
  align-items: flex-start;
}

.card-left {
  flex: 1;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 24rpx;
  color: #999999;
  display: flex;
  align-items: center;
}

.icon {
  margin-right: 8rpx;
}

.activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.member-count {
  font-size: 24rpx;
  color: #999999;
}

.activity-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-left: 24rpx;
  object-fit: cover;
}

.login-prompt {
  padding: 64rpx 32rpx;
}

.edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.edit-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 85vh;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.edit-panel-show {
  transform: translateY(0);
}

.edit-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.edit-header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.edit-header-btn {
  font-size: 28rpx;
  color: #666666;
  padding: 8rpx 16rpx;
  min-width: 80rpx;
}

.edit-header-save {
  color: #0052D9;
  font-weight: 500;
  text-align: right;
}

.edit-panel-body {
  flex: 1;
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
}

.avatar-upload-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
  gap: 16rpx;
}

.avatar-hint {
  font-size: 24rpx;
  color: #0052D9;
}

.form-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 32rpx 0 16rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

/* 邮箱状态行 */
.user-info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.verify-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.verify-badge.verified {
  color: #07c160;
  background: rgba(7, 193, 96, 0.15);
}

.verify-badge.unverified {
  color: #999999;
  background: rgba(0, 0, 0, 0.08);
}

/* 编辑面板邮箱字段 */
.email-form-item {
  cursor: pointer;
}

.email-field-display {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  min-height: 72rpx;
}

.email-field-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 邮箱验证弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1001;
}

.modal-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 48rpx 32rpx 80rpx;
  z-index: 1002;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal-panel-show {
  transform: translateY(0);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.modal-input {
  margin-bottom: 8rpx;
}

